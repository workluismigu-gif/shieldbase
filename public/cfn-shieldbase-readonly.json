{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "ShieldBase read-only security audit role for SOC 2 compliance scanning",
  "Resources": {
    "ShieldBaseReadOnlyRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "ShieldBaseReadOnly",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::886821787192:role/shieldbase-lambda-role"
              },
              "Action": "sts:AssumeRole",
              "Condition": {
                "StringEquals": {
                  "sts:ExternalId": "shieldbase-scan"
                }
              }
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/ReadOnlyAccess",
          "arn:aws:iam::aws:policy/SecurityAudit"
        ],
        "Tags": [
          { "Key": "CreatedBy", "Value": "ShieldBase" },
          { "Key": "Purpose", "Value": "SOC2-Compliance-Scanning" }
        ]
      }
    }
  },
  "Outputs": {
    "ShieldBaseRoleARN": {
      "Description": "Paste this ARN into ShieldBase to connect your AWS account",
      "Value": { "Fn::GetAtt": ["ShieldBaseReadOnlyRole", "Arn"] }
    }
  }
}
